<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
    <style>
        .same-line {
            display: flex;
            gap: 5px;
        }
        .card{
            border: 1px solid #cccc;
            width: 220px;
            border-radius: 4px;
            overflow: hidden;
        }
    </style>
</head>
<body>
    <h1>Dashboard</h1>
    <section>
        <p><b>Name:</b> <%= user.firstName %> <%= user.lastName %></p>
        <p><b>Email:</b> <%= user.email %> | <%= user.mobileNumber %></p>
        <p><b>Token:</b></p>
        <pre><%= user.token %></pre>
        <br>
    </section>
    <section>
        <h2>Add Product Section</h2>
        <form action="/add-product" method="POST" enctype="multipart/form-data">
            <div class="same-line">
                <input placeholder="product name" type="text" name="name" required />
                <input placeholder=" product category" type="text" name="category" required />
                <input placeholder="price" type="number" name="price" required />
                <input placeholder="quantity" type="number" name="quantity" required />
            </div>
            <br>
            <input type="file" name="image" accept="image/*" /><br><br>
            <button type="submit">Add Product</button>
        </form>
        <% if (success) { %>
            <p style="color: green;"><%= success %></p>
        <% } %>
        <% if (error) { %>
            <p style="color: red;"><%= error %></p>
        <% } %>
    </section>
    <section>
        <h2>Product List</h2>
        <div style="display: flex; flex-wrap: wrap; gap: 20px;">
            <% if (products && products.length > 0) { %>
                <% products.forEach(product => { %>
                    <div class="card">
                        <div style="width: 100%; height: 150px;">
                            <img 
                                src="<%= product.imageUrl %>" 
                                alt="<%= product.name %>"
                                style="width: 100%; height: 100%; object-fit: cover;"
                            />
                        </div>
                        <div style="padding: 10px;">
                            <p><b><%= product.category %></b> | <%= product.name %></p>
                            <p><b>Price:</b> ₹<%= product.price %></p>
                            <p><b>Qty:</b> <%= product.quantity %></p>
                            <p><b>Added:</b> <%= product.addedOn %></p> 
                            
                            <form action="/add-to-cart" method="POST">
                                <input type="hidden" name="productId" value="<%= product.id %>">
                                <button type="submit">➕ Add to Cart</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p>No products available</p>
            <% } %>
        </div>
    </section>

    <section>
        <h2>🛒 Shopping Cart</h2>
        <div id="cart-container">
            <table border="1" style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="background-color: #f2f2f2;">
                        <th style="padding: 10px;">Product</th>
                        <th style="padding: 10px;">Price</th>
                        <th style="padding: 10px;">Quantity</th>
                        <th style="padding: 10px;">Subtotal</th>
                        <th style="padding: 10px;">Action</th>
                    </tr>
                </thead>
                <tbody id="cart-body">
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" style="text-align: right; padding: 10px;"><b>Total Amount:</b></td>
                        <td colspan="2" style="padding: 10px;"><b>₹<span id="cart-total">0</span></b></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </section>

    <a href="/logout">Logout</a>
</body>
</html>