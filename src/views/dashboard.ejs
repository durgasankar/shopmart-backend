<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
    <style>
        .same-line {
            display: flex;
            gap: 5px;
        }
        .card {
            border: 1px solid #cccc;
            width: 220px;
            border-radius: 4px;
            overflow: hidden;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            padding: 10px;
            border: 1px solid #ddd;
        }
        .remove-btn {
            background-color: #ff4d4d;
            color: white;
            border: none;
            padding: 5px 10px;
            border-radius: 3px;
            cursor: pointer;
        }
        .qty-container {
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .action-inline-form {
            display: inline-block;
            margin: 0;
        }
    </style>
</head>
<body>
    <h1>Dashboard</h1>
    <section>
        <p><b>Name:</b> <%= user.firstName %> <%= user.lastName %></p>
        <p><b>Email:</b> <%= user.email %> | <%= user.mobileNumber %></p>
        <p><b>Token:</b></p>
        <pre><%= user.token %></pre>
        <br>
    </section>
    
    <section>
        <h2>Add Product Section</h2>
        <form action="/add-product" method="POST" enctype="multipart/form-data">
            <div class="same-line">
                <input placeholder="product name" type="text" name="name" required />
                <input placeholder=" product category" type="text" name="category" required />
                <input placeholder="price" type="number" name="price" required />
                <input placeholder="quantity" type="number" name="quantity" required />
            </div>
            <br>
            <input type="file" name="image" accept="image/*" /><br><br>
            <button type="submit">Add Product</button>
        </form>
        <% if (typeof success !== 'undefined' && success) { %>
            <p style="color: green;"><%= success %></p>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
            <p style="color: red;"><%= error %></p>
        <% } %>
    </section>

    <section>
        <h2>Product List</h2>
        <div style="display: flex; flex-wrap: wrap; gap: 20px;">
            <% if (products && products.length > 0) { %>
                <% products.forEach(product => { %>
                    <div class="card">
                        <div style="width: 100%; height: 150px;">
                            <img 
                                src="<%= product.imageUrl %>" 
                                alt="<%= product.name %>"
                                style="width: 100%; height: 100%; object-fit: cover;"
                            />
                        </div>
                        <div style="padding: 10px;">
                            <p><b><%= product.category %></b> | <%= product.name %></p>
                            <p><b>Price:</b> ₹<%= product.price %></p>
                            <p><b>Qty:</b> <%= product.quantity %></p>
                            <p><b>Added:</b> <%= product.addedOn %></p> 
                            
                            <form action="/add-to-cart" method="POST">
                                <input type="hidden" name="productId" value="<%= product.id %>">
                                <button type="submit">➕ Add to Cart</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p>No products available</p>
            <% } %>
        </div>
    </section>

    <section>
        <h2>🛒 Shopping Cart</h2>
        <div id="cart-container">
            <table>
                <thead>
                    <tr style="background-color: #f2f2f2;">
                        <th>Name</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Subtotal</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="cart-body">
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" style="text-align: right;"><b>Total Amount:</b></td>
                        <td colspan="2"><b>₹<span id="cart-total">0</span></b></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </section>

    <br>
    <a href="/logout">Logout</a>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const userEmail = "<%= user.email %>";
        
        socket.on("connect", () => {
            console.log("Connected with email:", userEmail);
            socket.emit("join", userEmail);
        });
        socket.on("cartUpdated", (updatedCart) => {
            console.log("Received live cart update:", updatedCart);
            renderCart(updatedCart);
        });

        // Dynamic Cart Rendering
        function renderCart(cartData) {
            const tbody = document.getElementById("cart-body");
            const totalSpan = document.getElementById("cart-total");
            tbody.innerHTML = "";
            if (!cartData || !cartData.items || cartData.items.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; padding: 20px;">Your cart is empty.</td></tr>';
                totalSpan.innerText = "0";
                return;
            }
            totalSpan.innerText = cartData.totalAmount || 0;
            cartData.items.forEach(item => {
                const subtotal = item.price * item.quantity;
                const row = document.createElement("tr");
                row.innerHTML = `
                    <td>${item.name}</td>
                    <td>₹${item.price}</td>
                    <td>
                        <div class="qty-container">
                            <form action="/cart-update" method="POST" class="action-inline-form">
                                <input type="hidden" name="productId" value="${item.productId}">
                                <input type="hidden" name="action" value="dec">
                                <button type="submit" class="qty-btn">-</button>
                            </form>
                            
                            <span><b>${item.quantity}</b></span>
                            
                            <form action="/cart-update" method="POST" class="action-inline-form">
                                <input type="hidden" name="productId" value="${item.productId}">
                                <input type="hidden" name="action" value="inc">
                                <button type="submit" class="qty-btn">+</button>
                            </form>
                        </div>
                    </td>
                    <td>₹${subtotal}</td>
                    <td>
                        <form action="/cart-remove" method="POST" class="action-inline-form">
                            <input type="hidden" name="productId" value="${item.productId}">
                            <button type="submit" class="remove-btn">Delete</button>
                        </form>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }
        
        const serverCartData = JSON.parse('<%- JSON.stringify(typeof cart !== "undefined" && cart ? cart : { items: [], totalAmount: 0 }) %>');
        renderCart(serverCartData);
    </script>
</body>
</html>