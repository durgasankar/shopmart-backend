<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
</head>
<body>
    <h2>Dashboard</h2>
    <p><b>First Name:</b> <%= user.firstName %></p>
    <p><b>Last Name:</b> <%= user.lastName %></p>
    <p><b>Email:</b> <%= user.email %></p>
    <p><b>Mobile Number:</b> <%= user.mobileNumber %></p>
    <p><b>Token:</b></p>
    <pre><%= user.token %></pre>
    <br>
    <a href="/logout">Logout</a>
</body>
</html>